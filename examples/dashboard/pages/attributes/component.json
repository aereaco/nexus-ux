{
  "Title": "data-component",
  "Description": "This page demonstrates the <code>data-component</code> attribute—the revolutionary lazy-loading template injesting engine powering this entire dashboard.",
  "Syntax": "<div data-component=\"/path/to/component.html\"></div>",
  "SourceModule": "/modules/attributes/component.ts",
  "SnippetModule": "data-component",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">The <code>src/modules/attributes/component.ts</code> loader mounts dynamically. Integrating a global HTTP cache interceptor significantly reduces template repaints in large layouts.</p>",
  "Snippet": "<div class=\"p-8 bg-base-200 rounded-box border shadow-inner\">\n    <div class=\"flex gap-4 mb-8\">\n        <button class=\"btn btn-outline btn-primary shadow-sm\" data-on-click=\"activeFragment = 'test_component_card.html'\">Load Component A</button>\n        <button class=\"btn btn-outline btn-secondary shadow-sm\" data-on-click=\"activeFragment = 'test_component_alert.html'\">Load Component B</button>\n        <button class=\"btn btn-error shadow-sm\" data-on-click=\"activeFragment = 'none'\">Destroy Component Tree</button>\n    </div>\n    \n    <div class=\"divider\">Ingested Component DOM Mount Point</div>\n    \n    <div data-show=\"activeFragment === 'none'\" class=\"h-32 flex items-center justify-center border-2 border-dashed border-base-300 rounded-xl text-base-content/50 font-medium bg-base-100\">\n        No component mounted. Awaiting fetch request...\n    </div>\n    \n    <div data-show=\"activeFragment !== 'none'\">\n        <!-- The actual component router fetching literal HTML files! -->\n        <div data-component=\"activeFragment\" style=\"min-height: 128px;\" class=\"border-2 border-primary rounded-xl overflow-hidden shadow-lg transition-all duration-300 bg-base-100\"></div>\n    </div>\n\n    <!-- Hidden template files mapping for this demonstration since we don't have secondary files -->\n    <template id=\"test_component_card.html\">\n        <div class=\"p-6 bg-primary text-primary-content\">\n            <h2 class=\"text-2xl font-bold mb-2\">Component A Loaded!</h2>\n            <p>I am an HTML fragment successfully fetched, extracted via RegExp, and mapped cleanly into the global AST scope.</p>\n        </div>\n    </template>\n    \n    <template id=\"test_component_alert.html\">\n         <div class=\"p-6 bg-secondary text-secondary-content\">\n            <h2 class=\"text-2xl font-bold mb-2\">Component B Loaded!</h2>\n            <p>This demonstrates completely modular micro-frontend construction directly inside purely declarative HTML files.</p>\n        </div>\n    </template>\n\n    <script>\n        // Very quick API mockup to hijack fetch to use the templates above for demo\n        if (!window.__fetch_hijacked) {\n            window.__fetch_hijacked = true;\n            const originalFetch = window.fetch;\n            window.fetch = async (url, options) => {\n                if (typeof url === 'string' && url.includes('test_component_card.html')) {\n                    const tpl = document.getElementById('test_component_card.html');\n                    return new Response(tpl.innerHTML, { headers: { 'content-type': 'text/html' }});\n                } else if (typeof url === 'string' && url.includes('test_component_alert.html')) {\n                    const tpl = document.getElementById('test_component_alert.html');\n                    return new Response(tpl.innerHTML, { headers: { 'content-type': 'text/html' }});\n                }\n                return originalFetch(url, options);\n            };\n        }\n    </script>\n</div>"
}
