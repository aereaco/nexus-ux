{
  "Title": "data-debug",
  "Description": "This page demonstrates the <code>data-debug</code> and <code>data-assert</code> development tools injecting native DevTools telemetry into the evaluation pipeline.",
  "Syntax": "<div data-debug=\"valueToLog\" data-assert-success=\"valueToLog > 5\"></div>",
  "SourceModule": "/modules/attributes/debug.ts",
  "SnippetModule": "data-debug",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">The AST diagnostic toolkit inside <code>src/modules/attributes/debug.ts</code> exposes active states. Hook this cleanly against external Sentry instances for automated telemetry logging.</p>",
  "Snippet": "<div class=\"p-8 bg-base-200 rounded-box border shadow-inner\">\n    <div class=\"alert alert-warning shadow-md mb-6\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"stroke-current shrink-0 h-6 w-6\" fill=\"none\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>\n        <div>\n            <h3 class=\"font-bold\">Open Your Browser Console!</h3>\n            <div class=\"text-sm\">Telemetry intercepts are triggering natively via the AST processing pipeline underneath.</div>\n        </div>\n    </div>\n\n    <!-- Will spam console when evaluated via Reactive Engine -->\n    <div data-debug=\"recordsParsed\" data-assert-success=\"recordsParsed > 0\" class=\"p-4 bg-base-100 rounded border border-base-300\">\n        <span class=\"font-mono text-sm\">Attached debugging node evaluating state validation rules behind the scenes.</span>\n        <div class=\"mt-4 form-control\">\n            <label class=\"label\"><span class=\"label-text\">Mutate Value (Triggers AST Recompilation Debug Dump)</span></label>\n            <input type=\"range\" class=\"range range-xs range-primary\" data-model=\"recordsParsed\" min=\"0\" max=\"500\">\n        </div>\n    </div>\n</div>"
}
