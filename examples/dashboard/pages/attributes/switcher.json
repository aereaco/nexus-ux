a-class-opacity-100=\"currentSlide === 'view-3'\" data-class-opacity-0=\"currentSlide !== 'view-3'\" data-class-pointer-events-none=\"currentSlide !== 'view-3'\">\n            <h2 class=\"text-4xl font-bold text-accent\">Configuration View</h2>\n            <p class=\"py-4 font-mono opacity-50\">View Layer Gamma unlocked...</p>\n        </div>\n    </div>\n</div>"
