{
  "Title": "data-pwa",
  "Description": "Demonstrates immediate architectural registration of an Offline Progressive Web App Service Worker via zero-js <code>data-pwa</code> instantiation.",
  "Syntax": "<div data-pwa=\"{ sw: '/sw.js' }\"></div>",
  "SourceModule": "/modules/attributes/pwa.ts",
  "SnippetModule": "data-pwa",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">The internal ServiceWorker bootstrapper in <code>src/modules/attributes/pwa.ts</code> orchestrates the offline navigator natively. Adjust caching techniques to enforce Stale-While-Revalidate physically.</p>",
  "Snippet": "<div class=\"p-8 bg-base-200 rounded-box border shadow-inner\">\n    <!-- Simple declarative attachment spins up the native SW lifecycle hook globally -->\n    <div class=\"alert alert-info shadow-lg w-full\" data-pwa=\"{ sw: '/examples/sw.js' }\" data-class-alert-success=\"#pwa.isInstalled\" data-class-alert-warning=\"!#pwa.isInstalled\">\n        <svg data-show=\"#pwa.isInstalled\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" class=\"stroke-current shrink-0 w-6 h-6\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n        <svg data-show=\"!#pwa.isInstalled\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" class=\"stroke-current shrink-0 w-6 h-6 animate-spin\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15\"></path></svg>\n        <div>\n            <h3 class=\"font-bold\" data-text=\"#pwa.isInstalled ? 'Service Worker Bound!' : 'Registering Service Worker...'\"></h3>\n            <div class=\"text-sm\">The <code>data-pwa</code> attribute evaluates configuration pathing to securely register the offline thread hook.</div>\n        </div>\n    </div>\n\n    <div class=\"stats bg-neutral text-neutral-content w-full shadow border border-neutral-content/20 mt-6\">\n        <div class=\"stat\">\n            <div class=\"stat-title border-b border-neutral-content/20 pb-2\">Cache Stratagem</div>\n            <div class=\"stat-value text-accent mt-2\">Network-First</div>\n            <div class=\"stat-desc\">Zero configuration required by default</div>\n        </div>\n    </div>\n</div>"
}
