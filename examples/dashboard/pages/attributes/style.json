  "SnippetModule": "data-style",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">Dynamic styles in <code>src/modules/attributes/style.ts</code> interface directly with <code>CSSStyleDeclaration</code>. Modding this allows polyfilling unsupported CSS properties natively.</p>",
  "Snippet": "<div class=\"p-8 bg-base-200 rounded-box border shadow-inner\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-base-200 p-8 rounded-box shadow-inner border border-base-300\">\n        <!-- Controls -->\n        <div class=\"flex flex-col gap-6 w-full\">\n            <div>\n                <label class=\"label\"><span class=\"label-text font-bold text-primary\">Rotation Axis (<span data-text=\"rotation + 'deg'\"></span>)</span></label>\n                <input type=\"range\" min=\"0\" max=\"360\" value=\"0\" class=\"range range-primary\" data-model=\"rotation\">\n            </div>\n            \n            <div>\n                <label class=\"label\"><span class=\"label-text font-bold text-secondary\">Scaling Factor (<span data-text=\"scale\"></span>)</span></label>\n                <input type=\"range\" min=\"0.5\" max=\"2\" step=\"0.1\" value=\"1\" class=\"range range-secondary\" data-model=\"scale\">\n            </div>\n            \n            <div class=\"flex items-center gap-4\">\n                <label class=\"font-bold\">Surface Pigment:</label>\n                <input type=\"color\" data-model=\"dynamicColor\" class=\"w-16 h-12 rounded cursor-pointer border-0 p-0\">\n            </div>\n        </div>\n\n        <!-- Visualization -->\n        <div class=\"flex items-center justify-center p-8 h-full\">\n            <div class=\"w-32 h-32 rounded-xl shadow-2xl flex items-center justify-center text-white font-bold text-center border-4 border-white/20 transition-all duration-300\" data-style-transform=\"`rotate(${rotation}deg) scale(${scale})`\" data-style-background-color=\"dynamicColor\">\n                AST<br>Rendered\n            </div>\n        </div>\n    </div>\n</div>"
