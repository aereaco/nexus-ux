{
  "Title": "data-for",
  "Description": "This page demonstrates declarative list rendering mapped entirely mathematically to array state mutation via <code>data-for</code>.",
  "Syntax": "<template data-for=\"item in items\">...</template>",
  "SourceModule": "/modules/attributes/for.ts",
  "SnippetModule": "data-for",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">Iterative rendering in <code>src/modules/attributes/for.ts</code> relies on deep Proxy cloning. This can be scaled physically using virtual-list mapping for 100k+ DOM node arrays.</p>",
  "Snippet": "<div class=\"overflow-x-auto mt-8 bg-base-200 rounded-box border shadow-inner\">\n    <table class=\"table table-zebra w-full text-lg\">\n        <thead>\n            <tr>\n                <th>ID</th>\n                <th>Asset Name</th>\n                <th>Stock Level</th>\n                <th>Actions</th>\n            </tr>\n        </thead>\n        <tbody>\n            <template data-for=\"(product, index) in inventory\">\n                <tr>\n                    <th data-text=\"product.id\" class=\"text-base-content/50 font-mono\"></th>\n                    <td data-text=\"product.item\" class=\"font-bold\"></td>\n                    <td>\n                        <div class=\"badge badge-lg p-3\" data-class-badge-error=\"product.stock < 10\" data-class-badge-success=\"product.stock >= 10\" data-text=\"product.stock\"></div>\n                    </td>\n                    <td>\n                        <button class=\"btn btn-error btn-sm\" data-on-click=\"inventory.splice(index, 1)\">Destroy Node</button>\n                    </td>\n                </tr>\n            </template>\n        </tbody>\n    </table>\n    \n    <div data-show=\"inventory.length === 0\" class=\"p-8 text-center text-error font-bold text-xl\">\n        All array nodes mathematically excised. The DOM holds nothing.\n    </div>\n</div>"
}
