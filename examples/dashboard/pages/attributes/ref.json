{
  "Title": "data-ref",
  "Description": "This page demonstrates the <code>data-ref</code> attribute registering physical DOM nodes directly into the <code>#refs</code> memory proxy for O(1) instantaneous access.",
  "Syntax": "<canvas data-ref=\"myCanvas\"></canvas>\n#refs.myCanvas.getContext('2d')",
  "SourceModule": "/modules/attributes/ref.ts",
  "SnippetModule": "data-ref",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">DOM Pointers inside <code>src/modules/attributes/ref.ts</code> bind to the root <code>Nexus</code> object. Adapting this yields jQuery-like collections if multiple elements declare identical refs.</p>",
  "Snippet": "<div class=\"p-8 bg-base-200 rounded-box border shadow-inner\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 bg-base-200 p-8 rounded-box border shadow-inner\">\n        <div class=\"flex flex-col gap-6\">\n            <!-- The Targeted Node -->\n            <div class=\"form-control w-full\">\n                <label class=\"label font-bold\">Physical Input Node</label>\n                <input type=\"text\" data-ref=\"secretInput\" class=\"input input-bordered w-full\" placeholder=\"Memory Address: #refs.secretInput\">\n            </div>\n            \n            <div class=\"form-control w-full\">\n                <label class=\"label font-bold\">Physical Canvas Node</label>\n                <canvas data-ref=\"drawSurface\" width=\"200\" height=\"100\" class=\"bg-base-100 border border-base-300 rounded shadow-inner w-full\"></canvas>\n            </div>\n        </div>\n\n        <div class=\"flex flex-col gap-4\">\n            <!-- Direct DOM Mutations Bypassing QuerySelector -->\n            <button class=\"btn btn-primary\" data-on-click=\"#refs.secretInput.focus(); #refs.secretInput.value = 'Auto-Filled via #refs!'\">\n                Focus &amp; Mutate Input Ref\n            </button>\n            \n            <button class=\"btn btn-secondary\" data-on-click=\"\n                const ctx = #refs.drawSurface.getContext('2d');\n                ctx.fillStyle = ['#ec4899', '#3b82f6', '#10b981', '#f59e0b'][Math.floor(Math.random() * 4)];\n                ctx.fillRect(Math.random()*150, Math.random()*50, 50, 50);\n            \">\n                Paint Native Canvas Ref\n            </button>\n            \n            <button class=\"btn btn-accent mt-4\" data-on-click=\"\n                // Demonstrating that #refs hold literal HTMLElement interfaces mapped from data-ref\n                #refs.secretInput.style.border = '4px solid #ec4899';\n                setTimeout(() => #refs.secretInput.style.border = '', 500);\n            \">\n                Flash Input Border Ref\n            </button>\n        </div>\n    </div>\n</div>"
}
