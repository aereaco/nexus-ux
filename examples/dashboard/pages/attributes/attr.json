  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">Attribute proxies in <code>src/modules/attributes/attr.ts</code> handle <code>setAttribute()</code>. Modify this to bind <code>aria-*</code> accessibility labels exclusively.</p>",
  "Snippet": "<div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 bg-base-200 p-8 rounded-box border shadow-inner\">\n    <!-- Disabled Boolean Mapping -->\n    <div class=\"bg-base-100 p-6 rounded-xl shadow-md border border-base-300 flex flex-col items-center\">\n        <h3 class=\"font-bold text-lg mb-4 opacity-70 border-b border-base-300 pb-2 w-full text-center\">Boolean Evaluation</h3>\n        <button class=\"btn w-full max-w-xs mb-6 shadow-sm\" data-class-btn-success=\"!isDisabled\" data-class-btn-warning=\"isDisabled\" data-attr-disabled=\"isDisabled\">\n            <span data-text=\"isDisabled ? 'LOCKED (AST Driven)' : 'UNLOCKED'\"></span>\n        </button>\n        \n        <label class=\"cursor-pointer label\">\n            <span class=\"label-text mr-4 font-bold\">Lock Interface Engine</span> \n            <input type=\"checkbox\" class=\"toggle toggle-warning\" data-model=\"isDisabled\">\n        </label>\n    </div>\n    \n    <!-- Href String Mapping -->\n    <div class=\"bg-base-100 p-6 rounded-xl shadow-md border border-base-300 flex flex-col items-center\">\n        <h3 class=\"font-bold text-lg mb-4 opacity-70 border-b border-base-300 pb-2 w-full text-center\">String Interpolation</h3>\n        \n        <input type=\"text\" data-model=\"linkTarget\" class=\"input input-bordered input-primary w-full max-w-xs mb-6 text-sm\">\n        \n        <a data-attr-href=\"linkTarget\" data-attr-title=\"`Externally linking to ${linkTarget}`\" target=\"_blank\" class=\"btn btn-outline btn-primary w-full max-w-xs\">\n            Execute Native Request\n            <svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewbox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\" class=\"w-5 h-5 ml-2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25\"></path>\n            </svg>\n        </a>\n    </div>\n</div>"
}
