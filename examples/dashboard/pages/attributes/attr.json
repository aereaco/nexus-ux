{
  "Title": "data-attr",
  "Description": "This page demonstrates abstract DOM attribute parameterization via <code>data-attr-*</code> binding properties such as <code>href</code>, <code>disabled</code>, or <code>src</code>.",
  "Syntax": "<input data-attr-disabled=\"isProcessing\">\n<a data-attr-href=\"dynamicLink\">",
