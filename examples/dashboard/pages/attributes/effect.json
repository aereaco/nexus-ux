{
  "Title": "data-effect",
  "Description": "Demonstrates the <code>data-effect</code> attribute which isolates raw mathematical side-effects. It triggers solely when its underlying memory tokens are mutated.",
  "Syntax": "<span data-effect=\"console.log(signalName)\"></span>",
  "SourceModule": "/modules/attributes/effect.ts",
  "SnippetModule": "data-effect",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">Side effects defined in <code>src/modules/attributes/effect.ts</code> execute silently. Extend this array memory to register explicit teardown hooks on node unmount.</p>",
  "Snippet": "<div class=\"mt-4 grid grid-cols-1 md:grid-cols-2 gap-8 p-8 bg-base-200 rounded-box border shadow-inner\">\n    <div class=\"flex flex-col gap-4\">\n        <label class=\"font-bold\">Mutate X Coordinate</label>\n        <input type=\"range\" class=\"range range-info range-sm\" data-model=\"activeTarget.pos.x\" min=\"0\" max=\"100\">\n        \n        <label class=\"font-bold mt-4\">Mutate Y Coordinate</label>\n        <input type=\"range\" class=\"range range-warning range-sm\" data-model=\"activeTarget.pos.y\" min=\"0\" max=\"100\">\n    </div>\n    \n    <div class=\"mockup-code bg-neutral text-neutral-content shadow-xl h-full flex flex-col items-center justify-center relative p-0 overflow-hidden min-h-[200px]\" data-effect=\"\n            // Note: this intrinsically maps to the container processing the AST effect\n            const box = this.querySelector('.tracking-box');\n            box.style.left = activeTarget.pos.x + '%';\n            box.style.top = activeTarget.pos.y + '%';\n            box.innerHTML = `(${activeTarget.pos.x}, ${activeTarget.pos.y})`;\n         \">\n        \n        <div class=\"tracking-box absolute w-16 h-16 bg-primary text-primary-content font-bold shadow-2xl rounded flex items-center justify-center text-xs transition-all duration-100 ease-out\" style=\"transform: translate(-50%, -50%);\">\n            <!-- Effect updates this element's position mathematically -->\n        </div>\n    </div>\n</div>"
}
