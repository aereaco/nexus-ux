{
  "Title": "data-signal",
  "Description": "Demonstrates defining explicitly isolated context blocks inside the DOM namespace mapping JSON literals to the AST Memory Engine via <code>data-signal</code>.",
  "Syntax": "<div data-signal=\"{ localCount: 0 }\"></div>",
  "SourceModule": "/modules/attributes/signal.ts",
  "SnippetModule": "data-signal",
  "Extensibility": "<p class=\"opacity-80 mt-4 leading-relaxed\">Located in <code>src/modules/attributes/signal.ts</code>, the signal directive parses JSON object literals and creates reactive state scopes. Signals cascade from parent to child nodes via the DOM data stack, enabling true DOM-as-State composition.</p><ul class=\"list-disc list-inside opacity-80 mt-3 space-y-1\"><li><strong>Local signals</strong> — Scoped to the element and its descendants</li><li><strong>Global signals</strong> — Use <code>data-signal:global</code> or <code>data-ux-init</code> for app-wide state</li><li><strong>Nested inheritance</strong> — Child signals inherit parent scope automatically</li><li><strong>Persistence</strong> — Combine with <code>_sessionStorage</code>, <code>_localStorage</code>, or <code>_indexedDB</code> mirrors</li></ul>",
  "Snippet": "<div>\n    <h3 class=\"font-bold text-xl uppercase opacity-60 mb-6\">\n        Inherited Parent Data\n    </h3>\n    <div class=\"stats bg-base-100 shadow mb-8 border border-base-300 w-full\">\n        <div class=\"stat\">\n            <div class=\"stat-title font-bold\">Cluster ID</div>\n            <div class=\"stat-value text-primary font-mono text-2xl\" data-text=\"cluster.id\"></div>\n        </div>\n        <div class=\"stat\">\n            <div class=\"stat-title font-bold\">Active Nodes</div>\n            <div class=\"stat-value text-secondary\" data-text=\"cluster.nodes\"></div>\n            <div class=\"stat-desc mt-3 flex gap-2\">\n                <button class=\"btn btn-sm btn-outline btn-secondary font-bold\" data-on-click=\"cluster.nodes++\">Add</button>\n                <button class=\"btn btn-sm btn-outline btn-error font-bold\" data-on-click=\"cluster.nodes--\">Remove</button>\n            </div>\n        </div>\n    </div>\n    <div data-signal=\"{ activeProcess: 'Training Model X' }\"\n         class=\"p-6 bg-accent/10 rounded-xl border border-accent/40 shadow\">\n        <h3 class=\"font-bold text-xl text-accent mb-4\">Nested Boundaries</h3>\n        <div class=\"form-control mb-4\">\n            <label class=\"label\"><span class=\"label-text font-bold text-accent\">Child: activeProcess</span></label>\n            <input type=\"text\" data-model=\"activeProcess\" class=\"input input-bordered border-accent bg-base-100 w-full\">\n        </div>\n        <div class=\"form-control\">\n            <label class=\"label\"><span class=\"label-text font-bold text-primary\">Parent: cluster.id</span></label>\n            <input type=\"text\" data-model=\"cluster.id\" class=\"input input-bordered border-primary bg-base-100 w-full\">\n        </div>\n    </div>\n</div>"
}
